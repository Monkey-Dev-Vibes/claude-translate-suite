{
  "name": "@monkey-dev-vibes/claude-translate-core",
  "version": "0.1.0",
  "description": "Reusable Claude translation primitives: API wrapper with streaming+retry, JSON parse with auto-retry, reviewer verdict parser, glossary block renderer, hard-rules block renderer.",
  "keywords": [
    "claude",
    "anthropic",
    "translation",
    "i18n",
    "llm",
    "retry",
    "json-parse",
    "glossary",
    "pipeline",
    "typescript"
  ],
  "homepage": "https://github.com/Monkey-Dev-Vibes/claude-translate-suite/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/Monkey-Dev-Vibes/claude-translate-suite/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Monkey-Dev-Vibes/claude-translate-suite.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": "monkey-dev-vibes",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
