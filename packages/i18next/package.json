{
  "name": "@monkey-dev-vibes/claude-translate-i18next",
  "version": "0.1.0",
  "description": "Two-pass Claude translation pipeline for i18next-style JSON locale files. Frozen-keys manifest, diff-mode, CLDR plural expansion, interpolation preservation, checkpoint resumability.",
  "keywords": [
    "i18next",
    "i18n",
    "translation",
    "localization",
    "l10n",
    "claude",
    "anthropic",
    "ai",
    "cldr",
    "plurals",
    "json",
    "react-i18next"
  ],
  "homepage": "https://github.com/monkey-dev-vibes/claude-translate-suite/tree/main/packages/i18next",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monkey-dev-vibes/claude-translate-suite.git",
    "directory": "packages/i18next"
  },
  "license": "MIT",
  "author": "monkey-dev-vibes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "claude-translate-i18next": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --clean --sourcemap",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@monkey-dev-vibes/claude-translate-core": "0.1.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
